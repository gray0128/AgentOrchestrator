{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent-orchestrator.plan-result.v1",
  "title": "PlanResult",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "role", "run_id", "issue", "summary", "risk", "implementation_steps", "test_plan", "expected_files", "created_at"],
  "properties": {
    "schema": { "const": "agent-orchestrator.plan-result.v1" },
    "role": { "const": "planner" },
    "run_id": { "type": "string", "pattern": "^run_[A-Za-z0-9_-]+$" },
    "issue": { "type": "integer", "minimum": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "risk": { "enum": ["low", "medium", "high"] },
    "implementation_steps": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "test_plan": { "type": "array", "items": { "type": "string" } },
    "expected_files": { "type": "array", "items": { "type": "string" } },
    "open_questions": { "type": "array", "items": { "type": "string" } },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
